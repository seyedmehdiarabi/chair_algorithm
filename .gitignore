# ویرایش .gitignore
cat > .gitignore << 'EOF'
# Python virtual environment
lib/
lib64/
bin/
include/
share/
pyvenv.cfg
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Project specific
temp/
cache/
*.tmp
*.log

# Python package info
*.egg-info/
*.egg
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.dmypy.json
dmypy.json
EOF